---
import { getCollection } from 'astro:content';
import { FEATURED_POSTS } from '../data/featured';

const days = await getCollection('days');
const allDays = days.length;
const featured = FEATURED_POSTS
  .map(f => {
    const day = days.find(d => d.data.dayNumber === f.dayNumber);
    if (!day) return null;
    return { ...f, subtitle: day.data.subtitle };
  })
  .filter((x): x is NonNullable<typeof x> => x !== null);
---
{featured.length > 0 && (
  <section class="max-w-5xl mx-auto px-8 py-20 border-t border-rule">
    <div class="mb-10">
      <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-3">CASE STUDIES · {featured.length} of {allDays}</div>
      <h2 class="font-display text-ink leading-[1.1] tracking-[-0.02em] font-semibold"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);">
        從 137 天裡<br />挑出來的真實片段。
      </h2>
    </div>
    <div class="border border-rule rounded-xl overflow-hidden bg-surface-1">
      {featured.map(f => (
        <a href={`/day/${f.dayNumber}`}
           class="grid grid-cols-[80px_1.4fr_2fr] gap-6 px-6 py-5 border-b border-rule last:border-b-0 hover:bg-surface-2 transition-colors duration-150 no-underline items-baseline">
          <span class="font-mono text-faint text-xs leading-tight">
            <span class="block text-ink text-2xl font-medium mb-0.5">{String(f.dayNumber).padStart(3, '0')}</span>
          </span>
          <span class="font-display text-ink text-[15px] font-medium">{f.customLabel}</span>
          <span class="font-display text-muted text-sm leading-relaxed">{f.subtitle}</span>
        </a>
      ))}
    </div>
    <div class="mt-5 text-right">
      <a href="/days" class="font-mono text-xs text-teal hover:text-ink transition-colors duration-150 no-underline">看所有 {allDays} 篇 →</a>
    </div>
  </section>
)}
