---
import { getCollection } from 'astro:content';
const days = await getCollection('days');
const totalDays = days.length;
---
<section class="relative max-w-5xl mx-auto px-8 pt-20 pb-16 overflow-hidden">
  <div aria-hidden="true" class="pointer-events-none absolute -top-40 -left-40 w-[640px] h-[640px] rounded-full opacity-60"
       style="background: radial-gradient(circle at center, color-mix(in oklab, var(--color-brick) 22%, transparent), transparent 60%);"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -bottom-40 -right-40 w-[560px] h-[560px] rounded-full opacity-50"
       style="background: radial-gradient(circle at center, color-mix(in oklab, var(--color-teal) 18%, transparent), transparent 60%);"></div>

  <div class="relative grid grid-cols-1 md:grid-cols-[1fr_280px] gap-10 md:gap-12 items-end">
    <div class="order-2 md:order-1">
      <span class="kicker">
        <span class="dot"></span>
        <span>Day {totalDays} · shipping daily</span>
      </span>
      <h1 class="font-display text-ink mt-6 mb-6"
          style="font-size: clamp(2.75rem, 6vw, 5rem); line-height: 1.02; letter-spacing: -0.03em; font-weight: 600; text-wrap: balance;">
        把 <span style="background: linear-gradient(90deg, var(--color-brick), var(--color-teal)); -webkit-background-clip: text; background-clip: text; color: transparent;">AI 工具</span><br />
        搬進你的<br />實際工作流。
      </h1>
      <p class="font-display text-muted text-lg leading-relaxed max-w-xl mb-6">
        9 年新創軟體經驗。過去 {totalDays} 天每天公開實作 AI 工作流 ——
        現在幫你的團隊把這套方法搬進生產環境。
      </p>
      <ul class="font-display text-muted text-base leading-relaxed max-w-xl mb-9 list-none p-0 m-0 space-y-2">
        <li class="relative pl-5 before:absolute before:left-0 before:top-3 before:w-3 before:h-px before:bg-teal">
          iOS → DevRel → Full Stack 跨領域工程經驗
        </li>
        <li class="relative pl-5 before:absolute before:left-0 before:top-3 before:w-3 before:h-px before:bg-teal">
          iPAS AI 應用規劃師（中級）能力鑑定 · 經濟部產業發展署發證
        </li>
        <li class="relative pl-5 before:absolute before:left-0 before:top-3 before:w-3 before:h-px before:bg-teal">
          已協助旅遊業把 AI 接進實際業務流程改善效率
        </li>
      </ul>
      <div class="flex flex-wrap gap-3 items-center">
        <a href="#inquire" class="btn-ink">預約 30 分鐘 →</a>
        <a href="#cases" class="btn-ghost">看最近 3 個諮詢案例 ↓</a>
      </div>
      <div class="mt-11 flex flex-wrap gap-x-9 gap-y-3 font-mono text-xs text-faint">
        <span class="flex gap-2"><span class="text-ink font-medium">{totalDays}</span><span>連續產出天數</span></span>
        <span class="flex gap-2"><span class="text-ink font-medium">9 yr</span><span>新創軟體經驗</span></span>
        <span class="flex gap-2"><span class="text-ink font-medium">2 wk</span><span>最短交付週期</span></span>
        <span class="flex gap-2"><span class="text-ink font-medium">100 %</span><span>原始碼公開</span></span>
      </div>
    </div>

    <aside class="order-1 md:order-2 max-w-[280px] md:max-w-none">
      <figure>
        <div class="relative">
          <span aria-hidden="true" class="absolute -top-2 -left-2 w-full h-full rounded-md"
                style="background: linear-gradient(135deg, color-mix(in oklab, var(--color-brick) 40%, transparent), color-mix(in oklab, var(--color-teal) 30%, transparent));"></span>
          <img
            src="/dawson.webp"
            alt="Dawson Wang，AI 工具落地實踐者"
            width="640"
            height="800"
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="relative block w-full aspect-[4/5] object-cover rounded-md border border-rule"
          />
        </div>
        <figcaption class="mt-3 font-mono text-[11px] text-faint flex justify-between items-baseline">
          <span>Dawson Wang</span>
          <span class="text-teal">已寫 {totalDays} 篇</span>
        </figcaption>
      </figure>
    </aside>
  </div>
</section>
