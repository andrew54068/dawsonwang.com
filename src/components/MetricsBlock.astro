---
import { formatViews } from '../lib/format';
import type { ParsedManifest } from '../lib/parse-manifest';

interface Props { manifest: ParsedManifest; }
const { manifest } = Astro.props;
const stats: { label: string; value: string }[] = [];
if (manifest.threads?.stats.views) stats.push({ label: 'Threads 觀看', value: formatViews(manifest.threads.stats.views) });
if (manifest.facebook?.stats.reactions) stats.push({ label: 'Facebook 互動', value: formatViews(manifest.facebook.stats.reactions) });
if (manifest.linkedin?.stats.impressions) stats.push({ label: 'LinkedIn 曝光', value: formatViews(manifest.linkedin.stats.impressions) });

const colClass = stats.length === 3 ? 'grid-cols-3' : stats.length === 2 ? 'grid-cols-2' : 'grid-cols-1';
---
{stats.length > 0 && (
  <div class={`my-8 grid ${colClass} gap-px bg-rule border border-rule rounded-lg overflow-hidden`}>
    {stats.map(s => (
      <div class="bg-surface-1 px-4 py-5 text-center">
        <div class="font-mono font-medium text-ink leading-none text-2xl">{s.value}</div>
        <div class="font-mono text-[10px] tracking-[.08em] uppercase text-faint mt-3">{s.label}</div>
      </div>
    ))}
  </div>
)}
