---
import Divider from './Divider.astro';
const year = new Date().getFullYear();
---
<div class="max-w-3xl mx-auto px-6 mt-20"><Divider /></div>
<footer>
  <div class="max-w-3xl mx-auto px-6 py-10 grid gap-6">
    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-3">
      <div class="font-serif font-bold text-lg text-ink">Dawson Wang</div>
      <div class="font-serif italic text-teal text-sm">我幫台灣團隊把 AI 工具落地</div>
      <a href="/#inquire" class="text-brick text-xs tracking-[.14em] uppercase font-sans font-semibold no-underline hover:text-ink transition-colors duration-150">聊聊合作 →</a>
    </div>
    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-3 text-xs font-sans">
      <ul class="flex gap-5 list-none p-0 m-0 text-muted">
        <li><a class="hover:text-ink transition-colors duration-150 no-underline" href="/days">所有文章</a></li>
        <li><a class="hover:text-ink transition-colors duration-150 no-underline" href="/topics">主題</a></li>
        <li><a class="hover:text-ink transition-colors duration-150 no-underline" href="/proof">作品集</a></li>
      </ul>
    </div>
    <div class="text-[10px] tracking-[.12em] uppercase text-muted font-sans border-t border-rule pt-4">
      排版採用 DM Serif Display &amp; Source Serif 4　·　以繁體中文書寫　·　© {year} Dawson Wang
    </div>
  </div>
</footer>
