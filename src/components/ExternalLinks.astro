---
import type { ParsedManifest } from '../lib/parse-manifest';
interface Props { manifest: ParsedManifest; }
const { manifest } = Astro.props;
const links: { label: string; href: string }[] = [];
if (manifest.threads) links.push({ label: 'Threads', href: manifest.threads.postUrl });
if (manifest.facebook) links.push({ label: 'Facebook', href: manifest.facebook.postUrl });
if (manifest.linkedin) links.push({ label: 'LinkedIn', href: manifest.linkedin.postUrl });
---
{links.length > 0 && (
  <div class="my-6">
    <div class="font-mono text-[10px] tracking-[.08em] uppercase text-teal mb-3">前往原帖</div>
    <ul class="space-y-1">
      {links.map(l => (
        <li>
          <a href={l.href} target="_blank" rel="noopener noreferrer"
             class="flex justify-between items-baseline font-display text-ink no-underline border-b border-rule py-2 hover:text-teal transition-colors duration-150">
            <span class="text-sm">{l.label}</span>
            <span class="font-mono text-xs text-faint">→</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
)}
