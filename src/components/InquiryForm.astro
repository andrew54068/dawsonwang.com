---
// Form posts to /api/inquiry — unchanged backend.
---
<section id="inquire" class="max-w-3xl mx-auto px-6 py-12 border-t-2 border-teal">
  <header class="eyebrow-pair">
    <span class="ey-left">聊聊合作</span>
    <span class="ey-right">填表後 1–2 個工作日內回覆</span>
  </header>
  <h2 class="font-display text-ink leading-tight tracking-[-0.01em]" style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);">
    告訴我你想用 AI <em class="italic text-teal">解決什麼</em>。
  </h2>
  <p class="font-serif text-base text-muted mt-3 max-w-xl">
    如果適合進一步聊，回信時會附上預約連結。
  </p>

  <form action="/api/inquiry" method="POST" class="grid gap-7 mt-10 max-w-xl">
    <input type="text" name="hp_field" value="" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

    <label class="grid gap-2">
      <span class="mag-label">姓名</span>
      <input type="text" name="name" required class="mag-input" />
    </label>

    <label class="grid gap-2">
      <span class="mag-label">Email</span>
      <input type="email" name="email" required class="mag-input" />
    </label>

    <label class="grid gap-2">
      <span class="mag-label">公司 / 組織</span>
      <input type="text" name="company" required class="mag-input" />
    </label>

    <label class="grid gap-2">
      <span class="mag-label">想用 AI 做什麼？</span>
      <textarea name="goal" required maxlength="300" rows="4" class="mag-input resize-none"></textarea>
      <span class="font-sans text-[10px] text-muted tracking-[.04em]">最多 300 字</span>
    </label>

    <fieldset class="grid gap-3 border-0 p-0">
      <legend class="mag-label">團隊規模</legend>
      <div class="flex flex-wrap gap-2">
        {['1-5', '6-30', '31-100', '100+'].map(v => (
          <label class="radio-chip">
            <input type="radio" name="team_size" value={v} required /><span>{v}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="grid gap-3 border-0 p-0">
      <legend class="mag-label">專案預算（NTD）</legend>
      <div class="flex flex-wrap gap-2">
        {[
          { v: 'lt100k', l: '< 10 萬' },
          { v: '100k-300k', l: '10–30 萬' },
          { v: '300k-800k', l: '30–80 萬' },
          { v: 'gt800k', l: '> 80 萬' },
        ].map(o => (
          <label class="radio-chip">
            <input type="radio" name="budget" value={o.v} required /><span>{o.l}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="grid gap-3 border-0 p-0">
      <legend class="mag-label">時程</legend>
      <div class="flex flex-wrap gap-2">
        {[
          { v: 'this_month', l: '本月內' },
          { v: 'this_quarter', l: '本季' },
          { v: 'exploring', l: '只是先了解' },
        ].map(o => (
          <label class="radio-chip">
            <input type="radio" name="timeline" value={o.v} required /><span>{o.l}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <button type="submit" class="btn-ink mt-4 justify-self-start">送出</button>
  </form>
</section>
