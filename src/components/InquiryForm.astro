---
// Progressive enhancement. Without JS the browser does a native POST and the
// server 303-redirects to /inquiry-received. With JS the submit is intercepted:
// strict client-side email check, then a fetch — so the visitor never lands on
// the bare 303 redirect page or a raw "Invalid payload" server response.
---
<section id="inquire" class="max-w-5xl mx-auto px-8 py-20 border-t border-rule">
  <div class="grid md:grid-cols-[1fr_1.1fr] gap-12 items-start">
    <div>
      <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-3">CONSULTATION · ASYNC</div>
      <h2 class="font-display text-ink leading-[1.1] tracking-[-0.02em] font-semibold"
          style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);">
        告訴我你想用 AI<br /><span class="text-teal">解決什麼</span>。
      </h2>
      <p class="font-display text-muted text-lg leading-relaxed mt-4 max-w-md">
        填表後 1–2 個工作日內回覆。<br />
        合適會附上預約連結；不合適會直接說。
      </p>
      <div class="mt-6 grid gap-2 font-mono text-xs text-faint">
        <div class="flex gap-3"><span class="text-teal">→</span><span>沒有 newsletter，沒有自動加群組</span></div>
        <div class="flex gap-3"><span class="text-teal">→</span><span>所有對話都會保密</span></div>
        <div class="flex gap-3"><span class="text-teal">→</span><span>報價在第二輪對話後給</span></div>
      </div>
      <div class="mt-6 pt-4 border-t border-rule font-mono text-[11px] text-faint uppercase tracking-[.08em]">
        最近諮詢的客戶來自：旅遊 · 醫療 · KOL 經紀 · 自媒體
      </div>
    </div>

    <form id="inquiry-form" action="/api/inquiry" method="POST"
          class="grid gap-6 bg-surface-1 border border-rule rounded-xl p-7">
      <input type="text" name="hp_field" value="" tabindex="-1" autocomplete="off" class="hidden" aria-hidden="true" />

      <label class="grid gap-2">
        <span class="mag-label">姓名</span>
        <input type="text" name="name" required class="mag-input" />
      </label>

      <label class="grid gap-2">
        <span class="mag-label">Email</span>
        <input
          type="email"
          name="email"
          id="inq-email"
          required
          autocomplete="email"
          aria-describedby="inq-email-hint"
          class="mag-input"
        />
        <span id="inq-email-hint" class="email-hint" aria-live="polite" hidden></span>
      </label>

      <label class="grid gap-2">
        <span class="mag-label">公司 / 組織</span>
        <input type="text" name="company" required maxlength="150" class="mag-input" />
      </label>

      <label class="grid gap-2">
        <span class="mag-label">想用 AI 做什麼？</span>
        <textarea
          name="goal"
          required
          maxlength="300"
          rows="4"
          class="mag-input resize-none"
        ></textarea>
        <span class="font-mono text-[10px] text-faint">最多 300 字</span>
      </label>

      <fieldset class="grid gap-3 border-0 p-0">
        <legend class="mag-label">團隊規模</legend>
        <div class="flex flex-wrap gap-2">
          {['1-5', '6-30', '31-100', '100+'].map(v => (
            <label class="radio-chip">
              <input type="radio" name="team_size" value={v} required /><span>{v}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="grid gap-3 border-0 p-0">
        <legend class="mag-label">預算量級（NTD）</legend>
        <div class="flex flex-wrap gap-2">
          {[
            { v: 'lt100k', l: '< 10 萬' },
            { v: '100k-300k', l: '10–30 萬' },
            { v: '300k-800k', l: '30–80 萬' },
            { v: 'gt800k', l: '> 80 萬' },
          ].map(o => (
            <label class="radio-chip">
              <input type="radio" name="budget" value={o.v} required /><span>{o.l}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="grid gap-3 border-0 p-0">
        <legend class="mag-label">時程</legend>
        <div class="flex flex-wrap gap-2">
          {[
            { v: 'this_month', l: '本月內' },
            { v: 'this_quarter', l: '本季' },
            { v: 'exploring', l: '只是先了解' },
          ].map(o => (
            <label class="radio-chip">
              <input type="radio" name="timeline" value={o.v} required /><span>{o.l}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <p id="inq-error" class="form-error" role="alert" hidden></p>
      <button type="submit" id="inq-submit" class="btn-ink mt-2 justify-self-start">送出 →</button>
    </form>

    <div id="inq-success" hidden tabindex="-1"
         class="grid gap-3 content-start bg-surface-1 border border-rule rounded-xl p-7">
      <div class="font-mono text-xs text-teal uppercase tracking-[.08em]">RECEIVED · OK</div>
      <h3 class="font-display text-ink text-2xl font-semibold tracking-[-0.02em]">
        <span class="text-teal">謝謝</span>。
      </h3>
      <p class="font-display text-muted leading-relaxed">
        我會在 1–2 個工作日內回信。如果適合進一步聊，會附上 Google Calendar 預約連結。
      </p>
    </div>
  </div>
</section>

<style>
  .email-hint,
  .form-error {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.4;
    letter-spacing: .02em;
    color: var(--color-ochre); /* design system's warning/highlight token */
  }
  .email-hint[hidden],
  .form-error[hidden] { display: none; }

  /* Gate the send button until the email passes the shared rule. */
  .btn-ink:disabled,
  .btn-ink:disabled:hover {
    opacity: 0.4;
    cursor: not-allowed;
  }
</style>

<script>
  // Mirror the server's email rule on the client and decide the submit outcome
  // in-page. The shared logic lives in src/lib/inquiry-client.ts (unit-tested);
  // this block is just the DOM glue.
  import {
    isValidInquiryEmail,
    inquiryErrorMessage,
    INQUIRY_EMAIL_HINT,
    INQUIRY_NETWORK_ERROR,
  } from '../lib/inquiry-client';

  const email = document.getElementById('inq-email') as HTMLInputElement | null;
  const hint = document.getElementById('inq-email-hint') as HTMLElement | null;
  const submit = document.getElementById('inq-submit') as HTMLButtonElement | null;
  const form = document.getElementById('inquiry-form') as HTMLFormElement | null;
  const errorEl = document.getElementById('inq-error') as HTMLElement | null;
  const success = document.getElementById('inq-success') as HTMLElement | null;

  if (email && hint && submit && form && errorEl && success) {
    const sendLabel = submit.textContent;

    const isValid = () => isValidInquiryEmail(email.value);

    // showError=false keeps the field quiet while still gating the button —
    // used on load so an untouched form doesn't shout at the user.
    function refresh(showError: boolean) {
      const valid = isValid();
      submit!.disabled = !valid;
      email!.setAttribute('aria-invalid', valid ? 'false' : 'true');
      const nag = !valid && showError && email!.value.trim().length > 0;
      hint!.textContent = nag ? INQUIRY_EMAIL_HINT : '';
      hint!.hidden = !nag;
    }

    email.addEventListener('input', () => refresh(true));
    email.addEventListener('blur', () => refresh(true));

    form.addEventListener('submit', async (e) => {
      // Always handle in-page: the visitor never sees the 303 redirect target
      // or a raw server error body.
      e.preventDefault();

      // Strict email check first (stricter than the browser's type=email).
      if (!isValid()) {
        refresh(true);
        email.focus();
        return;
      }
      // Let the browser surface its native messages for the other required fields.
      if (!form.reportValidity()) return;

      errorEl.hidden = true;
      submit.disabled = true;
      submit.textContent = '送出中…';

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          redirect: 'manual', // the server's 303 arrives as an opaqueredirect = success
        });
        const message = inquiryErrorMessage(res);
        if (message === null) {
          form.hidden = true;
          success.hidden = false;
          success.focus(); // move focus off the now-hidden form
          success.scrollIntoView({ block: 'center' });
          return;
        }
        errorEl.textContent = message;
      } catch {
        errorEl.textContent = INQUIRY_NETWORK_ERROR;
      }

      errorEl.hidden = false;
      submit.disabled = false;
      submit.textContent = sendLabel;
    });

    refresh(false);
  }
</script>

