---
interface Props { attribution?: string; }
const { attribution } = Astro.props;
---
<blockquote class="pullquote">
  <slot />
  {attribution && <span class="pullquote-attr">— {attribution}</span>}
</blockquote>
<style>
  .pullquote {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 22px;
    line-height: 1.35;
    color: var(--color-ink);
    padding: 20px 0;
    margin: 28px 0;
    border-top: 1px solid var(--color-teal);
    border-bottom: 1px solid var(--color-rule);
  }
  .pullquote-attr {
    display: block;
    margin-top: 12px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--color-teal);
  }
</style>
