---
interface Props { attribution?: string; }
const { attribution } = Astro.props;
---
<blockquote class="pullquote">
  <slot />
  {attribution && <span class="pullquote-attr">— {attribution}</span>}
</blockquote>
<style>
  .pullquote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    line-height: 1.3;
    color: var(--color-teal);
    padding: 16px 0 14px 0;
    margin: 22px 0;
    border-top: 2px solid var(--color-teal);
    border-bottom: 1px solid var(--color-rule);
    position: relative;
  }
  .pullquote::before {
    content: '\201C';
    font-family: var(--font-display);
    color: var(--color-ochre);
    font-size: 64px;
    line-height: 0;
    position: absolute;
    left: -8px;
    top: 26px;
  }
  .pullquote-attr {
    display: block;
    margin-top: 8px;
    font-family: var(--font-sans);
    font-size: 11px;
    font-style: normal;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--color-brick);
  }
</style>
