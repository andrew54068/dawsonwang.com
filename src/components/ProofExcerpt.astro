---
import { getCollection } from 'astro:content';
import { computeStatsSummary } from '../lib/metrics';
import StatsCharts from './StatsCharts.astro';

const days = await getCollection('days');
const stats = computeStatsSummary(days);
---
<section class="max-w-5xl mx-auto px-8 py-20 border-t border-rule">
  <div class="mb-10">
    <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-3">PROOF · {stats.totalDays} DAYS</div>
    <h2 class="font-display text-ink leading-[1.1] tracking-[-0.02em] font-semibold"
        style="font-size: clamp(1.75rem, 3.5vw, 2.5rem);">
      每天一篇 AI <span class="text-teal">工具實戰</span>。
    </h2>
    <p class="font-display text-muted text-lg leading-relaxed max-w-xl mt-3">
      從 Claude Code skill 到 Threads bot、再到資安研究。完整公開：源碼、流程、踩雷、結果。
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] gap-8 items-start">
    <aside class="bg-surface-1 border border-rule rounded-xl p-5">
      <div class="font-mono font-medium text-ink leading-none mb-3" style="font-size: 36px;">
        {stats.totalDays}
      </div>
      <div class="font-mono text-[11px] uppercase tracking-[.08em] text-faint">天連續產出</div>
    </aside>

    <StatsCharts stats={stats} />
  </div>

  <div class="mt-8 text-right">
    <a href="/proof" class="font-mono text-xs text-teal hover:text-ink transition-colors duration-150 no-underline">看完整作品集 →</a>
  </div>
</section>
