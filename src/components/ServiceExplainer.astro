---
import { SERVICES } from '../data/services';
import Divider from './Divider.astro';
const primary = SERVICES.find(s => s.primary)!;
const secondary = SERVICES.filter(s => !s.primary);
---
<div class="max-w-3xl mx-auto px-6"><Divider /></div>
<section class="max-w-3xl mx-auto px-6 py-12">
  <header class="eyebrow-pair">
    <span class="ey-left">合作方式</span>
    <span class="ey-right">三種介入深度</span>
  </header>

  <article class="mt-2">
    <div class="font-sans text-[10px] tracking-[.22em] uppercase text-brick font-semibold">主要服務</div>
    <h3 class="font-display text-ink mt-2 leading-tight tracking-[-0.01em]" style="font-size: clamp(1.5rem, 3vw, 2rem);">
      {primary.title}
    </h3>
    <p class="font-serif text-base text-ink leading-relaxed mt-3 max-w-2xl primary-blurb">
      {primary.blurb}
    </p>
    <ul class="font-serif text-[15px] text-ink mt-4 max-w-2xl">
      {primary.examples.map(e => (
        <li class="border-b border-rule py-2.5 last:border-b-0">{e}</li>
      ))}
    </ul>
    <a href={primary.ctaHref} class="btn-ink mt-6">{primary.ctaLabel}</a>
  </article>

  <div class="grid md:grid-cols-2 gap-8 mt-12 pt-6 border-t border-rule">
    {secondary.map(s => (
      <div>
        <div class="font-sans text-[10px] tracking-[.22em] uppercase text-muted font-semibold">{s.title}</div>
        <p class="font-serif text-sm text-ink mt-2 leading-relaxed">{s.blurb}</p>
        <ul class="font-serif text-sm text-muted mt-3 leading-relaxed">
          {s.examples.map(e => <li class="before:content-['·'] before:mr-2 before:text-brick">{e}</li>)}
        </ul>
        <a href={s.ctaHref} class="inline-block mt-3 font-sans text-xs uppercase tracking-[.14em] text-brick no-underline hover:text-ink transition-colors duration-150 font-semibold">
          {s.ctaLabel} →
        </a>
      </div>
    ))}
  </div>
</section>

<style>
  @media (min-width: 768px) {
    .primary-blurb {
      columns: 2;
      column-gap: 28px;
      column-rule: 1px solid var(--color-rule);
    }
  }
</style>
