---
import { getCollection } from 'astro:content';
import { renderMarkdown } from '../../lib/render-markdown';
import { readFileSync } from 'node:fs';
import path from 'node:path';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SlideCarousel from '../../components/SlideCarousel.astro';
import MetricsBlock from '../../components/MetricsBlock.astro';
import ExternalLinks from '../../components/ExternalLinks.astro';
import { isTopPerformer } from '../../lib/metrics';
import { topicsForDay, chipVariantFor, topicBySlug } from '../../lib/topics';
import { SITE_URL, cleanDescription, breadcrumbJsonLd, DEFAULT_OG_IMAGE, DEFAULT_OG_IMAGE_WIDTH, DEFAULT_OG_IMAGE_HEIGHT } from '../../lib/seo';
import Divider from '../../components/Divider.astro';

export async function getStaticPaths() {
  const days = await getCollection('days');
  return days.map(day => ({ params: { n: String(day.data.dayNumber) }, props: { day, allDays: days } }));
}

const { day, allDays } = Astro.props;
const slideAltBase = `Day ${day.data.dayNumber} ${day.data.subtitle || ''}`.trim();
const slides = day.data.slideFiles.map((p: string, i: number) => ({
  src: `/content/day${String(day.data.dayNumber).padStart(2, '0')}/slides/${p.split('/').pop()}`,
  alt: `${slideAltBase} — 投影片 ${i + 1}`,
}));

const dayPad = String(day.data.dayNumber).padStart(2, '0');
const shareFiles = (day.data.shareFiles as string[]).map((p: string) => ({
  name: p.split('/').pop()!,
  src: `/content/day${dayPad}/${p.split('/').pop()}`,
  isVideo: /\.mp4$/i.test(p),
}));
const squareVideo = shareFiles.find(f => f.isVideo && f.name.includes('square'));
const shareArtifact = squareVideo ?? shareFiles.find(f => f.isVideo) ?? shareFiles.find(f => !f.isVideo);

const bodyHtml = renderMarkdown(day.data.body);
const topicSlugs = topicsForDay(day.data.dayNumber);
const topics = topicSlugs.map(s => ({ slug: s, title: topicBySlug(s)?.title ?? s, variant: chipVariantFor(s) }));

const otherDays = allDays
  .filter((d: any) => d.data.dayNumber !== day.data.dayNumber)
  .sort((a: any, b: any) => b.data.dayNumber - a.data.dayNumber);
const sameTopic = topicSlugs.length > 0
  ? otherDays.filter((d: any) => topicsForDay(d.data.dayNumber).some(s => topicSlugs.includes(s)))
  : [];
const fill = otherDays.filter((d: any) => !sameTopic.includes(d));
const archive = [...sameTopic, ...fill].slice(0, 3);

const publishDate: string | null = day.data.manifest?.threads?.publishedAt
  ?? day.data.manifest?.facebook?.publishedAt
  ?? day.data.manifest?.linkedin?.publishedAt
  ?? null;
const articleDescription = cleanDescription(day.data.body, 155);
// Word count: CJK chars count as 1 each + ASCII whitespace-separated word tokens.
// This gives a reasonable schema.org `wordCount` for mixed zh-Hant / English bodies.
function computeWordCount(body: string): number {
  if (!body) return 0;
  const cjk = body.match(/[\u3400-\u9fff\u3040-\u30ff\uac00-\ud7af]/g)?.length ?? 0;
  const asciiTokens = body
    .replace(/[\u3400-\u9fff\u3040-\u30ff\uac00-\ud7af]/g, ' ')
    .split(/\s+/)
    .filter(t => /[A-Za-z0-9]/.test(t)).length;
  return cjk + asciiTokens;
}
const articleWordCount = computeWordCount(day.data.body);
const primarySection = topics[0]?.title;
const dayUrl = `${SITE_URL}/day/${day.data.dayNumber}`;
const repoRoot = process.cwd();

function pngDimensionsForPublicPath(publicPath: string) {
  const normalizedPath = publicPath.replace(/^\/+/, '');
  if (!normalizedPath.toLowerCase().endsWith('.png')) return undefined;

  try {
    const imageBytes = readFileSync(path.join(repoRoot, 'public', normalizedPath));
    if (imageBytes.length < 24 || imageBytes.toString('ascii', 1, 4) !== 'PNG') return undefined;

    return {
      width: imageBytes.readUInt32BE(16),
      height: imageBytes.readUInt32BE(20),
    };
  } catch {
    return undefined;
  }
}

// Social-card aspect-ratio guard (issue #162):
// `twitter:card=summary_large_image` (Twitter requires 2:1) and Facebook OG (1.91:1)
// both expect a wide image. Slide covers from 100days/content are authored at 1:1
// (1024×1024 / 1254×1254), which Twitter downgrades to a small-thumbnail card and
// Facebook/LinkedIn/Slack center-crop. If the candidate slide cover's aspect ratio
// falls outside [1.85, 2.05], fall back to the 1200×630 site default (which is
// known to be in-band) so the declared og:image dimensions always match the
// declared twitter:card type. The per-post alt text is preserved separately via
// the explicit ogImageAlt prop so the alt-text contract from existing CI probes
// (criterion 3) does not regress.
const OG_IMAGE_MIN_RATIO = 1.85;
const OG_IMAGE_MAX_RATIO = 2.05;
const slideCoverSrc = slides[0]?.src;
const slideCoverDims = slideCoverSrc ? pngDimensionsForPublicPath(slideCoverSrc) : undefined;
const slideCoverRatio = slideCoverDims && slideCoverDims.height > 0
  ? slideCoverDims.width / slideCoverDims.height
  : undefined;
const slideCoverIsSocialReady = slideCoverSrc !== undefined
  && slideCoverDims !== undefined
  && slideCoverRatio !== undefined
  && slideCoverRatio >= OG_IMAGE_MIN_RATIO
  && slideCoverRatio <= OG_IMAGE_MAX_RATIO;
const primaryOgImage = slideCoverIsSocialReady ? slideCoverSrc! : DEFAULT_OG_IMAGE;
const primaryOgImageDimensions = slideCoverIsSocialReady
  ? slideCoverDims!
  : { width: DEFAULT_OG_IMAGE_WIDTH, height: DEFAULT_OG_IMAGE_HEIGHT };
// Preserve the per-post alt text (e.g. "Day 173 我推的會議 bot 被 Google 擋了")
// even when we substitute the default OG image, so og:image:alt / twitter:image:alt
// continue to identify the article rather than the generic site default.
const primaryOgImageAlt = `Day ${day.data.dayNumber} ${day.data.subtitle || ''}`.trim();
// Primary Article image: og-default with known dimensions to qualify for the large-image
// Article rich result (Google guidance: declare width/height, prefer ≥1200px). Slide images
// from content/dayNN are added as secondary string entries when present — we don't have
// reliable dimensions for them at build time, so the typed primary is the dimension anchor.
const fallbackImage = {
  '@type': 'ImageObject',
  url: `${SITE_URL}${DEFAULT_OG_IMAGE}`,
  width: DEFAULT_OG_IMAGE_WIDTH,
  height: DEFAULT_OG_IMAGE_HEIGHT,
};
const slideImageUrls = slides.map(s => `${SITE_URL}${s.src}`);
const articleImage: unknown = slideImageUrls.length > 0
  ? [fallbackImage, ...slideImageUrls]
  : fallbackImage;
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: `Day ${day.data.dayNumber} ${day.data.subtitle}`,
  description: articleDescription,
  url: dayUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': dayUrl },
  inLanguage: 'zh-Hant-TW',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  author: { '@id': `${SITE_URL}/#person` },
  publisher: { '@id': `${SITE_URL}/#person` },
  copyrightHolder: { '@id': `${SITE_URL}/#person` },
  creator: { '@id': `${SITE_URL}/#person` },
  accountablePerson: { '@id': `${SITE_URL}/#person` },
  editor: { '@id': `${SITE_URL}/#person` },
  isAccessibleForFree: true,
  datePublished: publishDate ?? undefined,
  dateModified: publishDate ?? undefined,
  image: articleImage,
  keywords: topics.map(t => t.title),
  ...(topics.length > 0 ? { about: topics.map(t => ({ '@id': `${SITE_URL}/topics/${t.slug}#term` })) } : {}),
  wordCount: articleWordCount,
  ...(primarySection ? { articleSection: primarySection } : {}),
  breadcrumb: { '@id': `${dayUrl}#breadcrumb` },
};
const dayBreadcrumbJsonLd = breadcrumbJsonLd([
  { name: 'Home', url: '/' },
  { name: 'Days', url: '/days' },
  { name: `Day ${day.data.dayNumber} ${day.data.subtitle ?? ''}`.trim(), url: `/day/${day.data.dayNumber}` },
], dayUrl);
---
<BaseLayout title={`Day ${day.data.dayNumber} ${day.data.subtitle}`} description={articleDescription} type="article" ogImage={primaryOgImage} ogImageWidth={primaryOgImageDimensions.width} ogImageHeight={primaryOgImageDimensions.height} ogImageAlt={primaryOgImageAlt} structuredData={[articleJsonLd, dayBreadcrumbJsonLd]} publishedTime={publishDate ?? undefined} modifiedTime={publishDate ?? undefined} articleAuthorUrl={`${SITE_URL}/#person`} articleTags={topics.map(t => t.title)}>
  <article class="max-w-5xl mx-auto px-8 py-14" data-pagefind-body data-pagefind-meta={`day:${day.data.dayNumber}`}>
    <div class="grid grid-cols-1 md:grid-cols-[1fr_160px] gap-x-12 gap-y-6">

      <div class="min-w-0 max-w-2xl">
        <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-4">
          DAY {String(day.data.dayNumber).padStart(3, '0')}{publishDate ? ` · ${publishDate.slice(0, 10)}` : ''}
        </div>
        <h1 class="font-display text-ink leading-[1.02] tracking-[-0.03em] text-balance font-semibold" style="font-size: clamp(2rem, 4.5vw, 3.25rem);">
          {day.data.subtitle || `Day ${day.data.dayNumber}`}
        </h1>

        {topics.length > 0 && (
          <div class="mt-5 flex flex-wrap gap-1.5">
            {topics.map(t => (
              <a href={`/topics/${t.slug}`} class={`chip chip-${t.variant} no-underline`}>{t.title}</a>
            ))}
          </div>
        )}

        <Divider class="my-8" />

        {slides.length > 0 && <SlideCarousel slides={slides} />}

        {shareArtifact && slides.length === 0 && (
          <figure class="my-10">
            <div class="font-mono text-[11px] tracking-[.08em] uppercase text-teal mb-3">SHARE</div>
            <div class="relative aspect-square overflow-hidden border border-rule rounded-lg bg-surface-1">
              {shareArtifact.isVideo
                ? <video src={shareArtifact.src} autoplay loop muted playsinline class="w-full h-full object-contain" />
                : <img src={shareArtifact.src} alt={slideAltBase} class="w-full h-full object-contain" />
              }
            </div>
          </figure>
        )}

        <div class="prose prose-invert max-w-none
                    prose-headings:font-display prose-headings:text-ink prose-headings:font-semibold prose-headings:tracking-tight
                    prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:relative prose-h2:pl-3 prose-h2:before:content-[''] prose-h2:before:absolute prose-h2:before:left-0 prose-h2:before:top-1.5 prose-h2:before:bottom-1.5 prose-h2:before:w-[2px] prose-h2:before:bg-teal
                    prose-p:font-display prose-p:text-ink prose-p:leading-[1.7] prose-p:text-[16px]
                    prose-a:text-teal prose-a:no-underline prose-a:border-b prose-a:border-dotted prose-a:border-teal hover:prose-a:text-brick
                    prose-strong:text-ink prose-strong:font-semibold
                    prose-code:font-mono prose-code:text-ochre prose-code:bg-surface-1 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:text-[13px] prose-code:before:content-[''] prose-code:after:content-['']
                    prose-pre:bg-surface-1 prose-pre:border prose-pre:border-rule prose-pre:rounded-lg
                    prose-blockquote:font-display prose-blockquote:not-italic prose-blockquote:text-ink prose-blockquote:text-[18px] prose-blockquote:leading-snug prose-blockquote:border-t prose-blockquote:border-teal prose-blockquote:border-l-0 prose-blockquote:border-b prose-blockquote:border-b-rule prose-blockquote:pl-0 prose-blockquote:py-3"
             set:html={bodyHtml} />

        {day.data.manifest && isTopPerformer(day.data.dayNumber) && (
          <MetricsBlock manifest={day.data.manifest} />
        )}

        <aside class="mt-12 bg-surface-1 border border-rule rounded-xl p-7 relative overflow-hidden" data-pagefind-ignore>
          <span aria-hidden="true" class="absolute top-0 left-0 right-0 h-px"
                style="background: linear-gradient(90deg, var(--color-brick), var(--color-teal));"></span>
          <div class="font-mono text-[11px] uppercase tracking-[.08em] text-teal mb-1">作者</div>
          <h3 class="font-display text-ink text-xl font-semibold tracking-tight mt-1">Dawson Wang</h3>
          <p class="font-display text-muted text-sm leading-relaxed mt-3 max-w-prose">
            我幫台灣團隊把 AI 工具落地到日常工作流。從 PoC 到上線、再到團隊接手。9 年新創軟體開發經驗、前 iOS@Taipei 社群主持人。
          </p>
          <a href="/#inquire" class="btn-ochre mt-4">預約諮詢 →</a>
        </aside>

        {archive.length > 0 && (
          <section class="mt-12 pt-8 border-t border-rule" data-pagefind-ignore>
            <div class="flex justify-between items-baseline mb-5">
              <div class="font-mono text-xs text-teal uppercase tracking-[.08em]">延伸閱讀</div>
              <a href="/days" class="font-mono text-xs text-faint hover:text-ink transition-colors duration-150 no-underline">看完整 {allDays.length} 篇 →</a>
            </div>
            <div class="grid md:grid-cols-3 gap-5">
              {archive.map((d: any) => (
                <a href={`/day/${d.data.dayNumber}`} class="block no-underline group bg-surface-1 border border-rule rounded-lg p-4 hover:border-teal/40 transition-colors duration-150">
                  <span class="font-mono text-faint text-xs">DAY {String(d.data.dayNumber).padStart(3, '0')}</span>
                  <h4 class="font-display text-sm text-ink mt-2 leading-snug font-medium group-hover:text-teal transition-colors duration-150">{d.data.subtitle}</h4>
                </a>
              ))}
            </div>
          </section>
        )}
      </div>

      <aside class="md:sticky md:top-20 md:self-start order-first md:order-last md:pt-1">
        <div class="flex md:block items-baseline gap-5 flex-wrap">
          <div>
            <span class="font-mono font-medium text-ink leading-none block" style="font-size: 44px;">{String(day.data.dayNumber).padStart(3, '0')}</span>
            <span class="font-mono text-[10px] tracking-[.08em] uppercase text-faint mt-2 block">篇</span>
          </div>
          {isTopPerformer(day.data.dayNumber) && (
            <div class="md:mt-5">
              <span class="chip chip-ochre">熱門</span>
            </div>
          )}
          {day.data.manifest && (
            <div class="basis-full md:basis-auto md:mt-6 md:pt-5 md:border-t md:border-rule">
              <ExternalLinks manifest={day.data.manifest} />
            </div>
          )}
        </div>
      </aside>

    </div>
  </article>
</BaseLayout>
