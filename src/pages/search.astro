---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import { SITE_URL, absoluteUrl, breadcrumbJsonLd } from '../lib/seo';

const days = await getCollection('days');
const total = days.length;
const searchTitle = 'AI 工作流文章搜尋';
const searchDescription = `從 ${total} 篇 Dawson Wang 的 AI 工具落地日誌中，用關鍵字或語意搜尋 Claude Code、MCP、automation、內容流程與團隊導入案例。`;
const searchUrl = absoluteUrl('/search');
const searchResultsPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SearchResultsPage',
  '@id': `${SITE_URL}/search#searchresultspage`,
  name: searchTitle,
  description: searchDescription,
  url: searchUrl,
  inLanguage: 'zh-Hant-TW',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  about: { '@id': `${SITE_URL}/#person` },
  breadcrumb: { '@id': `${searchUrl}#breadcrumb` },
  potentialAction: {
    '@type': 'SearchAction',
    target: `${SITE_URL}/search?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};
const searchBreadcrumbJsonLd = breadcrumbJsonLd([
  { name: 'Home', url: '/' },
  { name: 'Search', url: '/search' },
], searchUrl);
---
<BaseLayout title={searchTitle} description={searchDescription} structuredData={[searchResultsPageJsonLd, searchBreadcrumbJsonLd]}>
  <article class="max-w-5xl mx-auto px-8 py-16" data-pagefind-ignore="all">
    <BreadcrumbNav items={[{ label: 'Home', href: '/' }, { label: 'Search' }]} />
    <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-4">SEARCH · {total} POSTS</div>
    <h1 class="font-display text-ink leading-[1.02] tracking-[-0.03em] text-balance font-semibold"
        style="font-size: clamp(2.5rem, 5vw, 4rem);">
      在<span class="text-teal">日誌</span>裡找東西。
    </h1>

    <form id="search-form" class="mt-10 max-w-2xl space-y-6" autocomplete="off">
      <div>
        <label for="q" class="mag-label block">查詢</label>
        <input
          id="q"
          name="q"
          type="search"
          class="mag-input"
          placeholder="輸入關鍵字或概念，例如：自動化、創業心法、prompt 設計…"
          aria-describedby="search-mode-hint"
          autofocus
        />
      </div>

      <fieldset class="flex flex-wrap items-baseline gap-3">
        <legend class="mag-label mr-2">模式</legend>
        <label class="radio-chip">
          <input type="radio" name="mode" value="keyword" checked />
          <span>關鍵字</span>
        </label>
        <label class="radio-chip">
          <input type="radio" name="mode" value="semantic" />
          <span>語意</span>
        </label>
        <span id="search-mode-hint" class="font-mono text-xs text-faint ml-auto">
          關鍵字本地索引 · 語意走雲端嵌入（首查約 1 秒）
        </span>
      </fieldset>
    </form>

    <div id="search-status" class="mt-6 font-mono text-xs text-faint min-h-[1.5em]"></div>

    <section id="search-results" class="mt-2 max-w-3xl"></section>
  </article>

  <script>
    import { semanticSearch, warmUpSemantic, type SemanticHit } from '../lib/semantic-search-client';

    const form = document.getElementById('search-form') as HTMLFormElement;
    const input = document.getElementById('q') as HTMLInputElement;
    const statusEl = document.getElementById('search-status') as HTMLDivElement;
    const resultsEl = document.getElementById('search-results') as HTMLDivElement;
    const modeRadios = form.querySelectorAll<HTMLInputElement>('input[name="mode"]');

    function getMode(): 'keyword' | 'semantic' {
      const checked = form.querySelector<HTMLInputElement>('input[name="mode"]:checked');
      return (checked?.value as 'keyword' | 'semantic') ?? 'keyword';
    }

    function setStatus(text: string) {
      statusEl.textContent = text;
    }

    function escapeHtml(s: string): string {
      return s
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;');
    }

    function renderEmpty(msg = '尚無結果') {
      resultsEl.innerHTML = `<p class="font-serif italic text-muted text-sm py-6">${escapeHtml(msg)}</p>`;
    }

    function renderResults(rows: Array<{ day: number; subtitle: string; excerpt?: string; meta?: string }>) {
      if (!rows.length) return renderEmpty();
      const html = rows
        .map(r => {
          const excerpt = r.excerpt
            ? `<span class="block font-serif text-sm text-muted leading-relaxed mt-1">${r.excerpt}</span>`
            : '';
          const meta = r.meta
            ? `<span class="toc-meta">${escapeHtml(r.meta)}</span>`
            : `<span class="toc-meta"></span>`;
          return `<a href="/day/${r.day}" class="toc-row group">
            <span class="toc-num">${r.day}</span>
            <span class="toc-title">${escapeHtml(r.subtitle || '')}${excerpt}</span>
            ${meta}
          </a>`;
        })
        .join('');
      resultsEl.innerHTML = html;
    }

    // ---------- pagefind (keyword) ----------
    let pagefindPromise: Promise<any> | null = null;
    function loadPagefind() {
      if (!pagefindPromise) {
        pagefindPromise = (async () => {
          try {
            // Pagefind is emitted at build time by the pagefind CLI; in dev it
            // does not exist. Build the URL dynamically so Vite's static
            // analyzer skips resolution and the runtime fetch is what fails
            // (caught below) instead of the dev transform step.
            const pagefindUrl = `${window.location.origin}/pagefind/pagefind.js`;
            const mod = await import(/* @vite-ignore */ pagefindUrl);
            await mod.options?.({ excerptLength: 30 });
            return mod;
          } catch (err) {
            throw new Error('關鍵字索引尚未產生。請執行 `yarn build` 後在 preview 模式測試。');
          }
        })();
      }
      return pagefindPromise;
    }

    async function runKeyword(q: string) {
      setStatus('搜尋中…');
      try {
        const pf = await loadPagefind();
        const search = await pf.search(q);
        const top = await Promise.all(search.results.slice(0, 15).map((r: any) => r.data()));
        const rows = top.map(d => {
          const day = parseInt(d.meta?.day ?? '0', 10);
          const subtitle = (d.meta?.title || '').replace(/\s*\|\s*Dawson Wang.*$/, '');
          return {
            day,
            subtitle,
            excerpt: d.excerpt as string,
          };
        });
        renderResults(rows);
        setStatus(`找到 ${search.results.length} 篇相關文章 · 關鍵字`);
      } catch (err: any) {
        renderEmpty(err?.message ?? '搜尋失敗');
        setStatus('');
      }
    }

    // ---------- semantic ----------
    let semanticWarmed = false;
    async function ensureSemantic() {
      if (semanticWarmed) return;
      setStatus('正在載入語意索引…');
      await warmUpSemantic();
      semanticWarmed = true;
    }

    async function runSemantic(q: string) {
      try {
        await ensureSemantic();
        setStatus('語意比對中…');
        const hits = await semanticSearch(q, 15);
        const rows = hits.map((h: SemanticHit) => ({
          day: h.doc.day,
          subtitle: h.doc.subtitle,
          excerpt: h.doc.snippet,
          meta: `相似度 ${(h.score * 100).toFixed(0)}%`,
        }));
        renderResults(rows);
        setStatus(`找到 ${rows.length} 篇相近文章 · 語意`);
      } catch (err: any) {
        renderEmpty(err?.message ?? '語意搜尋失敗');
        setStatus('');
      }
    }

    // ---------- input handling ----------
    let debounce: number | undefined;
    function schedule() {
      const q = input.value.trim();
      if (debounce) window.clearTimeout(debounce);
      if (!q) {
        renderEmpty('輸入查詢字以開始');
        setStatus('');
        return;
      }
      const mode = getMode();
      const delay = mode === 'semantic' ? 350 : 120;
      debounce = window.setTimeout(() => {
        if (mode === 'keyword') runKeyword(q);
        else runSemantic(q);
      }, delay);
    }

    input.addEventListener('input', schedule);
    modeRadios.forEach(r => r.addEventListener('change', () => {
      if (input.value.trim()) schedule();
    }));
    form.addEventListener('submit', e => {
      e.preventDefault();
      schedule();
    });

    // Honor ?q= so links from search engines (and the WebSite SearchAction
    // JSON-LD) land directly on a populated result set.
    const initialQuery = new URLSearchParams(window.location.search).get('q')?.trim() ?? '';
    if (initialQuery) {
      input.value = initialQuery;
      schedule();
    } else {
      renderEmpty('輸入查詢字以開始');
    }

    // Pre-fetch the active mode's index in the background so the first
    // search feels instant (semantic stays lazy until user picks it).
    loadPagefind().catch(() => { /* graceful in dev */ });
  </script>
</BaseLayout>
