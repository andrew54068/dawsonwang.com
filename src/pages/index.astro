---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedPosts from '../components/FeaturedPosts.astro';
import ProofExcerpt from '../components/ProofExcerpt.astro';
import ServiceExplainer from '../components/ServiceExplainer.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { SITE_URL } from '../lib/seo';
import { SERVICES } from '../data/services';

const homeDescription = 'Dawson Wang 幫台灣團隊把 AI 工具落地到實際工作流：Claude Code、客製 skills、MCP server、agent 工作流、團隊培訓與顧問陪跑。';
const inquireUrl = `${SITE_URL}/#inquire`;
const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${SITE_URL}/#ai-workflow-service`,
  name: 'Dawson Wang AI 工具落地服務',
  url: SITE_URL,
  image: `${SITE_URL}/dawson.webp`,
  areaServed: 'Taiwan',
  inLanguage: 'zh-Hant-TW',
  founder: { '@id': `${SITE_URL}/#person` },
  isPartOf: { '@id': `${SITE_URL}/#website` },
  serviceType: ['AI 工具落地', 'AI workflow implementation', 'Claude Code training', 'MCP server implementation', 'Agent workflow consulting'],
  description: homeDescription,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    '@id': `${SITE_URL}/#ai-workflow-service-catalog`,
    name: 'Dawson Wang AI 工具落地服務方案',
    inLanguage: 'zh-Hant-TW',
    isPartOf: { '@id': `${SITE_URL}/#website` },
    itemListElement: SERVICES.map((service, index) => ({
      '@type': 'Offer',
      position: index + 1,
      url: inquireUrl,
      availability: 'https://schema.org/InStock',
      itemOffered: {
        '@type': 'Service',
        name: service.title,
        description: service.blurb,
        serviceType: service.examples,
        provider: { '@id': `${SITE_URL}/#person` },
        areaServed: 'Taiwan',
      },
    })),
  },
};
const homePersonServiceGraphLinkJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE_URL}/#person`,
  worksFor: { '@id': `${SITE_URL}/#ai-workflow-service` },
};
---
<BaseLayout title="Dawson Wang" description={homeDescription} structuredData={[serviceJsonLd, homePersonServiceGraphLinkJsonLd]}>
  <Hero />
  <FeaturedPosts />
  <ProofExcerpt />
  <ServiceExplainer />
  <InquiryForm />
</BaseLayout>
