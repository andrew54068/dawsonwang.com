---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import { topicsForDay } from '../lib/topics';
import { isTopPerformer } from '../lib/metrics';
import { SITE_URL, absoluteUrl, breadcrumbJsonLd } from '../lib/seo';

const days = await getCollection('days');
const sorted = days.sort((a, b) => b.data.dayNumber - a.data.dayNumber);
const firstDay = sorted[sorted.length - 1]?.data.dayNumber ?? 1;
const lastDay = sorted[0]?.data.dayNumber ?? days.length;

const daysTitle = 'AI 工具落地文章索引';
const daysDescription = `瀏覽 Dawson Wang 連續 ${days.length} 天公開的 AI 工具落地文章：Claude Code、agent workflow、MCP、automation、團隊工作流與產品實驗筆記。`;

const daysUrl = `${SITE_URL}/days`;
const daysCollectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${daysUrl}#collection`,
  url: daysUrl,
  name: '所有文章',
  description: daysDescription,
  inLanguage: 'zh-Hant-TW',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  about: { '@id': `${SITE_URL}/#person` },
  breadcrumb: { '@id': `${daysUrl}#breadcrumb` },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sorted.length,
    itemListElement: sorted.map((day, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: absoluteUrl(`/day/${day.data.dayNumber}`),
      name: `Day ${day.data.dayNumber} ${day.data.subtitle}`,
    })),
  },
};

const daysBreadcrumbJsonLd = breadcrumbJsonLd([
  { name: 'Home', url: '/' },
  { name: 'All posts', url: '/days' },
], daysUrl);
---
<BaseLayout title={daysTitle} description={daysDescription} structuredData={[daysCollectionJsonLd, daysBreadcrumbJsonLd]}>
  <article class="max-w-5xl mx-auto px-8 py-16">
    <BreadcrumbNav items={[{ label: 'Home', href: '/' }, { label: 'Days' }]} />
    <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-3">ALL POSTS · {firstDay}—{lastDay}</div>
    <h1 class="font-display text-ink leading-[1.02] tracking-[-0.03em] font-semibold"
        style="font-size: clamp(2.5rem, 5vw, 4rem);">
      所有<span class="text-teal">文章</span>。
    </h1>
    <p class="font-display text-muted text-lg leading-relaxed mt-3 max-w-xl">
      共 {days.length} 篇，依日期倒序。
    </p>
    <div class="mt-10 border-t border-rule">
      {sorted.map(day => (
        <PostCard
          dayNumber={day.data.dayNumber}
          subtitle={day.data.subtitle}
          topicSlugs={topicsForDay(day.data.dayNumber)}
          isTopPerformer={isTopPerformer(day.data.dayNumber)}
        />
      ))}
    </div>
  </article>
</BaseLayout>
