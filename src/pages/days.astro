---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { topicsForDay } from '../lib/topics';
import { isTopPerformer } from '../lib/metrics';

const days = await getCollection('days');
const sorted = days.sort((a, b) => b.data.dayNumber - a.data.dayNumber);
const firstDay = sorted[sorted.length - 1]?.data.dayNumber ?? 1;
const lastDay = sorted[0]?.data.dayNumber ?? days.length;
---
<BaseLayout title="所有文章" description="121+ 天 AI 學習實作日記">
  <article class="max-w-3xl mx-auto px-6 py-12">
    <header class="eyebrow-pair">
      <span class="ey-left">第 {firstDay} — {lastDay} 篇</span>
      <span class="ey-right">依日期倒序</span>
    </header>
    <h1 class="font-display text-ink leading-tight tracking-[-0.02em] text-balance" style="font-size: clamp(2.25rem, 5vw, 3.5rem);">
      所有<em class="italic text-teal">文章</em>。
    </h1>
    <div class="top-divider"></div>
    <div>
      {sorted.map(day => (
        <PostCard
          dayNumber={day.data.dayNumber}
          subtitle={day.data.subtitle}
          topicSlugs={topicsForDay(day.data.dayNumber)}
          isTopPerformer={isTopPerformer(day.data.dayNumber)}
        />
      ))}
    </div>
  </article>
</BaseLayout>
