---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TopicCard from '../../components/TopicCard.astro';
import { topicsWithPosts, daysForTopic } from '../../lib/topics';
import { SITE_URL, breadcrumbJsonLd } from '../../lib/seo';

const topics = topicsWithPosts().map(t => ({
  ...t,
  count: daysForTopic(t.slug).length,
}));
const topicTitleList = topics.map(topic => topic.title).join('、');

// DefinedTermSet hub: models the topic list as a controlled vocabulary / taxonomy.
// Single source of truth — references only topics backed by at least one tagged day,
// so placeholder / zero-post topics do not leak into crawlable taxonomy surfaces.
const topicTaxonomyJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': `${SITE_URL}/topics#topic-taxonomy`,
  name: 'AI 實作主題分類',
  description: `Dawson Wang 的 ${topics.length} 個 AI 工具落地主題分類：${topicTitleList}。`,
  inLanguage: 'zh-Hant-TW',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  hasDefinedTerm: topics.map(t => ({ '@id': `${SITE_URL}/topics/${t.slug}#term` })),
};
const topicsIndexUrl = `${SITE_URL}/topics`;
const topicsIndexTitle = 'AI 工具落地主題索引';
const topicsIndexDescription = `依主題瀏覽 Dawson Wang 的 ${topics.length} 個 AI 工具落地分類：${topicTitleList}。`;
const topicCollectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${topicsIndexUrl}#collection`,
  url: topicsIndexUrl,
  name: 'AI 實作主題',
  description: topicsIndexDescription,
  inLanguage: 'zh-Hant-TW',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  about: { '@id': `${SITE_URL}/#person` },
  breadcrumb: { '@id': `${topicsIndexUrl}#breadcrumb` },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: topics.length,
    itemListElement: topics.map((topic, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${SITE_URL}/topics/${topic.slug}`,
      name: topic.title,
      description: topic.blurb,
    })),
  },
};
const topicsIndexBreadcrumbJsonLd = breadcrumbJsonLd([
  { name: 'Home', url: '/' },
  { name: 'Topics', url: '/topics' },
], topicsIndexUrl);
---
<BaseLayout title={topicsIndexTitle} description={topicsIndexDescription} structuredData={[topicTaxonomyJsonLd, topicCollectionJsonLd, topicsIndexBreadcrumbJsonLd]}>
  <article class="max-w-5xl mx-auto px-8 py-16">
    <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-4">TOPICS · {topics.length} CATEGORIES</div>
    <h1 class="font-display text-ink leading-[1.02] tracking-[-0.03em] text-balance font-semibold"
        style="font-size: clamp(2.5rem, 5vw, 4rem);">
      依<span class="text-teal">主題</span>瀏覽。
    </h1>
    <div class="mt-10 border border-rule rounded-xl overflow-hidden bg-surface-1">
      {topics.map(t => <TopicCard {...t} />)}
    </div>
  </article>
</BaseLayout>
