---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { topicBySlug, daysForTopic, topicsWithPosts, topicsForDay, chipVariantFor } from '../../lib/topics';
import { isTopPerformer } from '../../lib/metrics';
import { SITE_URL, breadcrumbJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  const days = await getCollection('days');
  const validDayNumbers = days.map(day => day.data.dayNumber);
  return topicsWithPosts(validDayNumbers).map(t => ({ params: { slug: t.slug } }));
}

const { slug } = Astro.params;
const topic = topicBySlug(slug as string);
if (!topic) throw new Error(`Unknown topic: ${slug}`);

const days = await getCollection('days');
const validDayNumbers = days.map(day => day.data.dayNumber);
const tagged = daysForTopic(slug as string, validDayNumbers);
const filtered = days.filter(d => tagged.includes(d.data.dayNumber))
  .sort((a, b) => b.data.dayNumber - a.data.dayNumber);

const variant = chipVariantFor(topic.slug);
const topicUrl = `${SITE_URL}/topics/${topic.slug}`;
const topicPageTitle = `${topic.title} AI 實作文章`;
const topicPageDescription = `${topic.blurb} 收錄 ${filtered.length} 篇 Dawson Wang 的 AI 工具落地文章與案例。`;
const topicJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': `${topicUrl}#collection`,
  url: topicUrl,
  name: topic.title,
  description: topicPageDescription,
  inLanguage: 'zh-Hant-TW',
  isPartOf: { '@id': `${SITE_URL}/#website` },
  about: {
    '@type': 'DefinedTerm',
    '@id': `${topicUrl}#term`,
    name: topic.title,
    description: topicPageDescription,
    url: topicUrl,
    inDefinedTermSet: { '@id': `${SITE_URL}/topics#topic-taxonomy` },
  },
  breadcrumb: { '@id': `${topicUrl}#breadcrumb` },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: filtered.length,
    itemListElement: filtered.map((day, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: `${SITE_URL}/day/${day.data.dayNumber}`,
      name: `Day ${day.data.dayNumber} ${day.data.subtitle}`,
    })),
  },
};
const topicBreadcrumbJsonLd = breadcrumbJsonLd([
  { name: 'Home', url: '/' },
  { name: 'Topics', url: '/topics' },
  { name: topic.title, url: `/topics/${topic.slug}` },
], topicUrl);
---
<BaseLayout title={topicPageTitle} description={topicPageDescription} structuredData={[topicJsonLd, topicBreadcrumbJsonLd]}>
  <article class="max-w-5xl mx-auto px-8 py-16">
    <div class="font-mono text-xs text-teal uppercase tracking-[.08em] mb-4">TOPIC · {filtered.length} POSTS</div>
    <div class="flex items-baseline gap-3 mb-3">
      <span class={`chip chip-${variant}`}>{topic.slug}</span>
    </div>
    <h1 class="font-display text-ink leading-[1.02] tracking-[-0.03em] text-balance font-semibold"
        style="font-size: clamp(2.5rem, 5vw, 4rem);">
      {topic.title}
    </h1>
    <p class="font-display text-muted text-lg leading-relaxed mt-3 max-w-2xl">
      {topic.blurb}
    </p>
    <div class="mt-10 border-t border-rule">
      {filtered.map(day => (
        <PostCard
          dayNumber={day.data.dayNumber}
          subtitle={day.data.subtitle}
          topicSlugs={topicsForDay(day.data.dayNumber)}
          isTopPerformer={isTopPerformer(day.data.dayNumber)}
        />
      ))}
    </div>
  </article>
</BaseLayout>
